# Neon pooled URL for request-driven traffic
DATABASE_URL=postgresql://user:password@ep-example-pooler.region.aws.neon.tech/forge?sslmode=require
# Neon direct URL for migrations
DIRECT_URL=postgresql://user:password@ep-example.region.aws.neon.tech/forge?sslmode=require
DATABASE_MAX_CONNECTIONS=10
AUTH_SECRET=replace-with-at-least-32-random-characters
# Neon Auth. Keep legacy password access only for local migration/testing.
NEON_AUTH_ISSUER=https://ep-example.neonauth.region.aws.neon.tech/forge/auth
NEON_AUTH_JWKS_URL=https://ep-example.neonauth.region.aws.neon.tech/forge/auth/.well-known/jwks.json
NEON_AUTH_AUDIENCE=
ALLOW_LEGACY_AUTH=false
VITE_NEON_AUTH_URL=https://ep-example.neonauth.region.aws.neon.tech/forge/auth
VITE_ALLOW_LEGACY_AUTH=false
# Stripe Billing. Price IDs are selected only by the API from plan/currency keys.
# Prefer a least-privilege restricted key per service/environment.
STRIPE_RESTRICTED_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SOLO_BRL=
STRIPE_PRICE_SOLO_USD=
STRIPE_PRICE_STUDIO_BRL=
STRIPE_PRICE_STUDIO_USD=
STRIPE_PRICE_SCALE_BRL=
STRIPE_PRICE_SCALE_USD=
BILLING_GRACE_DAYS=3
# Signed Forge -> Benchline partner API.
BENCHLINE_API_URL=https://benchline.netolabs.dev/api
BENCHLINE_S2S_SECRET=
BENCHLINE_TIMEOUT_MS=8000
GOOGLE_API_KEY=
# Alternative to GOOGLE_API_KEY: use Vertex AI with Application Default Credentials
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
EVAL_SUPERVISOR_MODEL=gemini-2.5-pro
# Secret used by Vercel Cron to invoke the durable knowledge worker
CRON_SECRET=replace-with-a-random-64-character-secret
# Poll interval for `pnpm worker`
WORKER_POLL_MS=1500
# Optional JSON price override, e.g. {"gemini-2.5-flash":{"inputPerMillion":0.3,"outputPerMillion":2.5}}
GOOGLE_PRICING_JSON=
WEB_ORIGIN=http://localhost:5173
API_PORT=4000
