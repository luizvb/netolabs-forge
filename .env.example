# Neon pooled URL for request-driven traffic
DATABASE_URL=postgresql://user:password@ep-example-pooler.region.aws.neon.tech/forge?sslmode=require
# Neon direct URL for migrations
DIRECT_URL=postgresql://user:password@ep-example.region.aws.neon.tech/forge?sslmode=require
DATABASE_MAX_CONNECTIONS=10
AUTH_SECRET=replace-with-at-least-32-random-characters
GOOGLE_API_KEY=
# Alternative to GOOGLE_API_KEY: use Vertex AI with Application Default Credentials
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
EVAL_SUPERVISOR_MODEL=gemini-2.5-pro
WEB_ORIGIN=http://localhost:5173
API_PORT=4000
