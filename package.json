{
  "name": "netolabs-forge",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "license": "MIT",
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "pnpm --filter @forge/db build && pnpm --parallel --filter './apps/*' dev",
    "build": "pnpm -r build",
    "start:api": "pnpm --filter @forge/api build && node apps/api/dist/server.js",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "audit:prod": "corepack pnpm@11.13.0 --pm-on-fail=ignore audit --prod",
    "db:generate": "pnpm --filter @forge/db generate",
    "db:migrate": "pnpm --filter @forge/db migrate",
    "db:local": "pglite-server --db=./.local-postgres --port=54329",
    "smoke:local": "node scripts/smoke-local.mjs",
    "worker": "pnpm --filter @forge/api build && node apps/api/dist/worker.js"
  },
  "dependencies": {
    "fastify": "^5.6.1"
  },
  "devDependencies": {
    "@electric-sql/pglite-socket": "^0.1.5"
  }
}
