{
  "name": "@forge/db",
  "private": true,
  "type": "module",
  "exports": {
    ".": { "types": "./src/index.ts", "import": "./dist/src/index.js" },
    "./schema": { "types": "./src/schema.ts", "import": "./dist/src/schema.js" }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate"
  },
  "dependencies": { "drizzle-orm": "^0.45.2", "postgres": "^3.4.7" },
  "devDependencies": { "@types/node": "^22.18.12", "drizzle-kit": "^0.31.10", "typescript": "^5.9.3", "vitest": "^3.2.4" }
}
